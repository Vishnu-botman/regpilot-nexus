{
  "name": "regpilot-nexus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RegPilot Nexus - Regulatory Compliance MCP Server",
  "scripts": {
    "postinstall": "node -e \"const fs = require('fs'); if (fs.existsSync('prisma/schema.prisma')) { require('child_process').execSync('npx prisma generate', { stdio: 'inherit' }); } else { console.log('Prisma schema not found, skipping code generation.'); }\"",
    "dev": "nitrostack-cli dev",
    "build": "prisma generate && nitrostack-cli build",
    "start": "npm run build && nitrostack-cli start",
    "start:prod": "nitrostack-cli start",
    "upgrade": "nitrostack-cli upgrade",
    "install:all": "nitrostack-cli install",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "widget": "npm --prefix src/widgets",
    "worker": "tsx src/worker.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": ">=0.1.0",
    "@nitrostack/core": "^1.0.13",
    "@prisma/client": "^6.10.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.3.1",
    "node-cron": "^4.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nitrostack/cli": "^1.0.14",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.10.0",
    "typescript": "^5.3.3"
  },
  "author": "yedhu",
  "nitrostack": {
    "skillsVersion": "1.0.0"
  }
}
